---
// NEW section. The engineering case for sizing small, from the field: a large
// array on an existing building triggers structural, switchgear, permitting,
// and utility-transformer work that no one prices at the quote, each with its
// own lead time. Efficiency-first shrinks the array under those triggers (so
// jobs that were too big to build now pencil) and pays from day one on the
// upgrades that are unavoidable at any size (value while the long-lead gear
// is on order).
import Disc from "../Disc.astro";

const triggers = [
  {
    key: "roof",
    head: "Roof and structure",
    body: "A large array means a structural and wind-load study before a single panel mounts. The roof has to be proven able to carry the weight and the uplift.",
  },
  {
    key: "switchgear",
    head: "Service and switchgear",
    body: "Legacy service entrance and bus gear often can't back-feed solar. Replacing it is expensive, and the equipment is currently running 40 to 50 weeks out.",
  },
  {
    key: "permitting",
    head: "Permitting",
    body: "City and utility permitting cycles are long on their own. One red-lined resubmittal restarts the clock and pushes the close out another quarter.",
  },
  {
    key: "transformer",
    head: "Utility transformer",
    body: "The grid transformer may not accept the energy a large system pushes back. Upgrades carry long utility lead times and high charges, and they land after you've signed.",
  },
];
---

<section class="section bc" id="big-cost" aria-labelledby="bc-title">
  <div class="container">
    <div class="bc__head reveal">
      <p class="bc__eyebrow">Engineering reality</p>
      <h2 class="bc__title" id="bc-title">The cost a panel-only quote can't see.</h2>
      <p class="bc__lede lede">
        Bolt a big array onto an existing building and you're not just buying
        panels. You can trigger a chain of structural, electrical, and utility
        upgrades no one priced at the quote, each with its own lead time, and
        each landing after the client has signed.<Disc to="results" />
      </p>
    </div>

    <ul class="bc__grid">
      {triggers.map((t, i) => (
        <li class="bc__card reveal" style={`--i: ${i}`}>
          <span class="bc__card-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 3.5 1.8 21h20.4L12 3.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /><path d="M12 10v5" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><circle cx="12" cy="18.2" r="0.6" fill="currentColor" stroke="currentColor" stroke-width="1.2" /></svg>
          </span>
          <h3 class="bc__card-head">{t.head}</h3>
          <p class="bc__card-body">{t.body}</p>
        </li>
      ))}
    </ul>

    <div class="bc__payoff reveal">
      <article class="bc__win">
        <h3 class="bc__win-head">Smaller arrays clear the bar.</h3>
        <p class="bc__win-body">
          Cut the load first and the array can drop under the thresholds that
          force these upgrades, so a project that was too big to pencil becomes
          one you can actually build.
        </p>
      </article>
      <article class="bc__win">
        <h3 class="bc__win-head">Value while you wait.</h3>
        <p class="bc__win-body">
          When an upgrade is unavoidable at any size, efficiency still pays from
          day one. The client banks savings straight through a 40-to-50-week
          lead time instead of sitting on a stalled solar job.
        </p>
      </article>
    </div>

    <p class="bc__kicker reveal">
      The smallest system that meets the goal is the one that actually gets
      built.
    </p>
  </div>
</section>

<style>
  .bc {
    border-top: 1px solid var(--line);
    background:
      radial-gradient(ellipse 46% 42% at 96% 0%, color-mix(in srgb, var(--cost) 12%, transparent), transparent 70%),
      var(--bg);
  }
  .bc__head { max-width: 54rem; }
  .bc__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cost);
    margin-bottom: var(--space-xs);
  }
  .bc__title { font-size: var(--step-3); max-width: 20ch; }
  .bc__lede { margin-top: var(--space-m); max-width: 58ch; }

  .bc__grid {
    list-style: none;
    margin: var(--space-xl) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }
  .bc__card {
    padding: clamp(1.2rem, 3vw, 1.6rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .bc__card-ico {
    display: inline-grid;
    place-items: center;
    width: 1.7rem; height: 1.7rem;
    color: var(--cost);
    margin-bottom: var(--space-s);
  }
  .bc__card-ico svg { width: 1.7rem; height: 1.7rem; }
  .bc__card-head {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    color: var(--ink);
    line-height: 1.2;
  }
  .bc__card-body {
    margin-top: var(--space-2xs);
    font-size: var(--step--1);
    line-height: 1.55;
    color: var(--body);
  }

  .bc__payoff {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1.4rem, 3.5vw, 2.2rem);
    border: 1px solid color-mix(in srgb, var(--mint) 36%, transparent);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--mint-soft), transparent 60%), var(--surface);
  }
  .bc__win-head {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .bc__win-body {
    margin-top: var(--space-s);
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--body);
    max-width: 42ch;
  }

  .bc__kicker {
    margin-top: var(--space-xl);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink);
    max-width: 26ch;
    text-wrap: balance;
  }

  @media (max-width: 60rem) {
    .bc__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 40rem) {
    .bc__grid { grid-template-columns: 1fr; }
    .bc__payoff { grid-template-columns: 1fr; }
  }
</style>
