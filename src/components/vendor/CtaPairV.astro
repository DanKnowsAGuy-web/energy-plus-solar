---
// Vendor-facing CTA pair: "Apply Now" (Cal.com booking) + "Just text the
// founder".
//
// The text-the-founder button adapts to the device:
//   - Mobile: one tap fires an sms: deep link, opening Messages with the note
//     prefilled. No form, no editable box.
//   - Desktop (where sms: does nothing): reveals a QR code that, when scanned
//     with a phone, opens Messages prefilled to Dan, plus a prefilled email
//     fallback. The QR is generated at build time (no runtime/external calls).
import QRCode from "qrcode";

const { size = "" } = Astro.props;
const lg = size === "lg" ? " btn--lg" : "";

const PHONE = "+18647770688";
const PHONE_DISPLAY = "(864) 777-0688";
const EMAIL = "dan@danknowsaguy.org";
const MSG =
  "Hi Dan, I sell solar and I'd like to add an efficiency-first offering so I can shrink system sizing, close more deals, and open a new profit center. How does the white-label partnership work?";
const CAL_LINK = "dan-knows-a-gut/15min";

// Build-time QR. SMSTO is the canonical QR payload for a pre-filled SMS and is
// the format phone cameras recognize most reliably. Dark modules on white so it
// stays scannable against the dark panel.
// width is baked into the SVG so it sizes correctly even though Astro's scoped
// styles don't reach set:html-injected markup.
const qrSvg = await QRCode.toString(`SMSTO:${PHONE}:${MSG}`, {
  type: "svg",
  margin: 1,
  width: 132,
  errorCorrectionLevel: "M",
  color: { dark: "#0f1418", light: "#ffffff" },
});
const mailtoHref =
  `mailto:${EMAIL}?subject=${encodeURIComponent("Solar partner inquiry")}` +
  `&body=${encodeURIComponent(MSG)}`;
---

<div class="tf-cta" data-phone={PHONE} data-msg={MSG}>
  <div class="tf-cta__row">
    <button
      type="button"
      class={`btn js-book-toggle${lg}`}
      data-cal-namespace="15min"
      data-cal-link={CAL_LINK}
      data-cal-config='{"layout":"month_view","theme":"dark"}'
    >
      Apply Now
      <span class="btn__arrow" aria-hidden="true">&rarr;</span>
    </button>
    <button type="button" class={`btn btn--ghost js-tf-toggle${lg}`} aria-expanded="false">
      Just text the founder
    </button>
  </div>

  <!-- Desktop-only reveal (mobile taps go straight to Messages via JS). -->
  <div class="tf-panel" role="group" aria-label="Text the founder">
    <div class="tf-qr">
      <div class="tf-qr__code" set:html={qrSvg}></div>
      <div class="tf-qr__copy">
        <p class="tf-qr__lead">Point your phone's camera here to text Dan, message ready to send.</p>
        <p class="tf-qr__num">{PHONE_DISPLAY}</p>
        <a class="tf-qr__email" href={mailtoHref}>
          Or email Dan instead
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12 h13 M12 5 l7 7 -7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    if (window.__tfInit) return;
    window.__tfInit = true;
    const ua = navigator.userAgent || "";
    const isIOS = /iP(hone|ad|od)/.test(ua) || (/Mac/.test(ua) && "ontouchend" in document);
    // "Can this device send an SMS from a tap?" Coarse pointer covers phones and
    // tablets; the UA check is a backstop.
    const isMobile =
      matchMedia("(pointer: coarse)").matches || /Android|iP(hone|ad|od)/i.test(ua);

    const ensureCal = () => {
      if (window.__calReady) return;
      window.__calReady = true;
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if (typeof namespace === "string") { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]); } else p(cal, ar); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
      window.Cal("init", "15min", { origin: "https://app.cal.com" });
      window.Cal.config = window.Cal.config || {};
      window.Cal.config.forwardQueryParams = true;
      window.Cal.ns["15min"]("ui", { hideEventTypeDetails: false, layout: "month_view", theme: "dark", cssVarsPerTheme: { dark: { "cal-brand": "#46cfd6" } } });
    };
    if (document.readyState === "complete") setTimeout(ensureCal, 900);
    else addEventListener("load", () => setTimeout(ensureCal, 900));
    ["pointerdown", "touchstart", "keydown", "scroll"].forEach((ev) =>
      addEventListener(ev, ensureCal, { once: true, passive: true }),
    );

    const closeTf = (cta) => {
      const panel = cta.querySelector(".tf-panel");
      if (panel) panel.classList.remove("is-open");
      const t = cta.querySelector(".js-tf-toggle");
      if (t) t.setAttribute("aria-expanded", "false");
    };

    document.addEventListener("click", (e) => {
      const bookT = e.target.closest(".js-book-toggle");
      if (bookT) { ensureCal(); closeTf(bookT.closest(".tf-cta")); return; }

      const tfT = e.target.closest(".js-tf-toggle");
      if (tfT) {
        const cta = tfT.closest(".tf-cta");
        // Mobile: skip the panel, open Messages prefilled in one tap.
        if (isMobile) {
          const phone = cta.getAttribute("data-phone") || "";
          const msg = cta.getAttribute("data-msg") || "";
          window.location.href = "sms:" + phone + (isIOS ? "&" : "?") + "body=" + encodeURIComponent(msg);
          return;
        }
        // Desktop: reveal the scan-to-text QR + email fallback.
        const panel = cta.querySelector(".tf-panel");
        const willOpen = !panel.classList.contains("is-open");
        panel.classList.toggle("is-open", willOpen);
        tfT.setAttribute("aria-expanded", String(willOpen));
        return;
      }
    });
  })();
</script>

<style>
  .tf-cta { width: 100%; }
  .tf-cta__row { display: flex; flex-wrap: wrap; gap: var(--space-s); align-items: center; }

  /* text-the-founder panel: smooth in-place expand (desktop only) */
  .tf-panel {
    overflow: hidden; max-height: 0; opacity: 0;
    transition: max-height 0.5s var(--ease-out-quart), opacity 0.35s ease, margin-top 0.5s var(--ease-out-quart);
  }
  .tf-panel.is-open { max-height: 26rem; opacity: 1; margin-top: var(--space-m); }

  .tf-qr {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
    max-width: 34rem;
    padding: var(--space-m);
    border: 1px solid color-mix(in srgb, var(--mint) 30%, transparent);
    background: var(--mint-soft);
    border-radius: 16px;
  }
  .tf-qr__code {
    flex: none;
    background: #fff;
    padding: 10px;
    border-radius: 12px;
    line-height: 0;
  }
  /* :global because the SVG is injected via set:html and carries no scope id */
  .tf-qr__code :global(svg) { display: block; width: 132px; height: 132px; }
  .tf-qr__copy { display: grid; gap: 0.3rem; min-width: 12rem; flex: 1 1 12rem; }
  .tf-qr__lead {
    font-size: var(--step--1);
    line-height: 1.45;
    color: var(--body);
    max-width: 26ch;
  }
  .tf-qr__num {
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--ink);
    letter-spacing: 0.02em;
  }
  .tf-qr__email {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    margin-top: 0.15rem;
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--gold-text);
    text-decoration: none;
  }
  .tf-qr__email svg { width: 1em; height: 1em; }
  .tf-qr__email:hover { text-decoration: underline; }

  @media (prefers-reduced-motion: reduce) {
    .tf-panel { transition: opacity 0.3s ease; }
  }
</style>
