---
// Vendor reframe of FinalCta.
import CtaPair from "./CtaPairV.astro";
import Disc from "../Disc.astro";
---

<section class="section final" id="book" aria-labelledby="final-title">
  <div class="container">
    <div class="final__inner reveal">
      <h2 class="final__title" id="final-title">
        Stop losing solar deals to a number you could have shrunk.
      </h2>
      <p class="final__lede">
        Fifteen minutes. We look at your deal flow, tell you whether the
        white-label program fits, and show you exactly how we'd diagnose a
        building, cut its load, and re-size the array, on a real deal of yours.
        No projection, no pressure.
      </p>

      <p class="final__promise">
        <span class="final__promise-dot" aria-hidden="true"></span>
        <span>
          <strong>Verify first, commit after.</strong> The diagnosis is on us.
          Nothing is installed, and no one owes anything, until we prove the
          savings floor at the client's own meter.<Disc to="terms" />
        </span>
      </p>

      <div class="final__actions">
        <CtaPair size="lg" />
        <span class="final__aside">We typically have a same-week slot.<Disc to="terms" /></span>
      </div>
    </div>
  </div>
</section>

<style>
  .final {
    border-top: 1px solid var(--line);
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, var(--mint-soft), transparent 70%),
      var(--bg);
  }
  .final__inner { max-width: 44rem; }
  .final__title { font-size: var(--step-4); line-height: 1.08; letter-spacing: -0.02em; max-width: 18ch; }
  .final__lede { margin-top: var(--space-l); font-size: var(--step-1); line-height: 1.5; color: var(--body); max-width: 52ch; }
  .final__promise {
    margin-top: var(--space-l);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: start;
    padding: var(--space-m);
    border: 1px solid color-mix(in srgb, var(--mint) 32%, transparent);
    border-radius: var(--radius-s);
    background: color-mix(in srgb, var(--mint) 6%, transparent);
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--body);
    max-width: 50rem;
  }
  .final__promise strong { color: var(--ink); }
  .final__promise-dot {
    width: 0.7rem; height: 0.7rem; margin-top: 0.45rem;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--mint) 60%, transparent);
  }
  .final__actions {
    margin-top: var(--space-l);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-m);
  }
  .final__aside { font-family: var(--font-mono); font-size: var(--step--1); color: var(--muted); }
</style>
