---
// NEW section. The margin story: one client, two phases, two revenue events.
// Phase 1 efficiency is a profit center the panel-only vendor never books;
// Phase 2 solar closes faster because Phase 1 already shrank and de-risked it.
import CtaPair from "./CtaPairV.astro";

const phases = [
  {
    n: "Phase 1",
    title: "Efficiency",
    lede: "Resell the stack that cuts the load. You earn on the measures themselves, and you walk in as the partner who lowered the bill before asking for a cent toward panels.",
    points: [
      "Margin on HVAC, refrigeration, harmonization, and demand work",
      "A bill that's already lower funds the next phase",
      "You own the relationship instead of bidding on the panel",
    ],
  },
  {
    n: "Phase 2",
    title: "Solar",
    lede: "Now size the array to the smaller load. The system is cheaper, the payback is shorter, and the objections you used to lose to are already answered.",
    points: [
      "A smaller system that finally pencils for the client",
      "Faster close: the hard 'no' is now a staged 'yes'",
      "Full margin on the solar you were going to sell anyway",
    ],
  },
];
---

<section class="section profit" id="profit" aria-labelledby="profit-title">
  <div class="container">
    <div class="profit__head reveal">
      <h2 class="profit__title" id="profit-title">Two profit centers. One client.</h2>
      <p class="profit__lede lede">
        The panel-only vendor gets one shot at one sale. Lead with efficiency
        and the same client becomes two revenue events, and the second one
        closes because the first one happened.
      </p>
    </div>

    <div class="profit__flow">
      {phases.map((p, i) => (
        <>
          <article class={`profit__phase profit__phase--${i + 1} reveal`} style={`--i: ${i}`}>
            <p class="profit__phase-n">{p.n}</p>
            <h3 class="profit__phase-title">{p.title}</h3>
            <p class="profit__phase-lede">{p.lede}</p>
            <ul class="profit__points">
              {p.points.map((pt) => (
                <li>
                  <span class="profit__pt-ico" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </span>
                  {pt}
                </li>
              ))}
            </ul>
          </article>
          {i === 0 && (
            <div class="profit__arrow reveal" aria-hidden="true">
              <svg viewBox="0 0 48 24" fill="none"><path d="M2 12 h40 M34 4 l8 8 -8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </div>
          )}
        </>
      ))}
    </div>

    <p class="profit__kicker reveal">
      The vendor who solves the whole bill is the one the client never puts out
      to bid again.
    </p>

    <div class="profit__cta reveal">
      <CtaPair />
    </div>
  </div>
</section>

<style>
  .profit {
    border-top: 1px solid var(--line);
    background:
      radial-gradient(ellipse 44% 40% at 6% 100%, var(--gold-soft), transparent 70%),
      var(--bg);
  }
  .profit__head { max-width: 54rem; }
  .profit__title { font-size: var(--step-3); max-width: 18ch; }
  .profit__lede { margin-top: var(--space-m); max-width: 56ch; }

  .profit__flow {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: stretch;
  }
  .profit__phase {
    padding: clamp(1.3rem, 3.5vw, 2rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .profit__phase--2 {
    border-color: color-mix(in srgb, var(--mint) 36%, transparent);
    background: linear-gradient(180deg, var(--mint-soft), transparent 55%), var(--surface);
  }
  .profit__phase-n {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-text);
  }
  .profit__phase--2 .profit__phase-n { color: var(--mint); }
  .profit__phase-title {
    margin-top: 0.3rem;
    font-family: var(--font-serif);
    font-size: var(--step-2);
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .profit__phase-lede { margin-top: var(--space-s); font-size: var(--step-0); line-height: 1.55; color: var(--body); }
  .profit__points { list-style: none; margin: var(--space-m) 0 0; padding: 0; display: grid; gap: 0.7rem; }
  .profit__points li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.6rem;
    align-items: start;
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--body);
  }
  .profit__pt-ico { display: inline-grid; place-items: center; width: 1.2rem; height: 1.2rem; margin-top: 0.05rem; color: var(--mint); }
  .profit__pt-ico svg { width: 1.2rem; height: 1.2rem; }

  .profit__arrow { display: grid; place-items: center; color: var(--gold-text); }
  .profit__arrow svg { width: clamp(2rem, 4vw, 3rem); height: auto; }

  .profit__kicker {
    margin-top: var(--space-xl);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink);
    max-width: 30ch;
    text-wrap: balance;
  }
  .profit__cta { margin-top: var(--space-l); }

  @media (max-width: 46rem) {
    .profit__flow { grid-template-columns: 1fr; }
    .profit__arrow { transform: rotate(90deg); padding: var(--space-2xs) 0; }
  }
</style>
